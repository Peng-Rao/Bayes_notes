x=seq(-10,10,0.01)
u=seq(0,1,0.01)
n=100
ypdf=dnorm(x)
yCDF=pnorm(x)
yquantile=qnorm(u)
normalsample=rnorm(n)
plot(x,ypdf,type="l",col="red")
plot(x,yCDF,type="l",col="blue",lwd=2,lty=3,xlab="x",ylab="CDF")
plot(u,yquantile,col="gold",lwd=1,lty=2,xlab="u",ylab="Quantile",main="Quantile of a N(0,1)")
plot(seq(1,n,1),normalsample,xlab="n",ylab="observations")
hist(normalsample,30)
help(dgamma)
x=seq(0,10,0.01) # fix the range in x
u=seq(0,1,0.01) # grid on (0,1)
n=100 # number of samples
shp=2 # shape
rat=3 # rate
ypdf=dgamma(x,shape=shp,rate=rat) # pdf
yCDF=pgamma(x,shape=shp,rate=rat) # CDF
yquantile=qgamma(u,shape=shp,rate=rat) # quantile
normalsample=rgamma(100,shape=shp,rate=rat) # random sample
# make a plot
name=paste("of a","Gamma(",shp,",",rat,")",sep="")
plot(x,ypdf,type="l",col="red",xlab="x",ylab="pdf",main=paste("pdf",name,sep=" "))
plot(x,yCDF,type="l",col="blue",lwd=2,lty=3,xlab="x",ylab="CDF",main=paste("CDF",name,sep=" "))
plot(u,yquantile,col="gold",lwd=1,lty=2,xlab="u",ylab="Quantile",main=paste("Quantile",name,sep=" "))
plot(seq(1,n,1),normalsample,xlab="n",ylab="observations", main="random sample")
hist(normalsample)
data0=rnorm(100,0,1)
# compute and plot an histogram of x
# hist(data0,prob=T) basic command... below with few more parameters
hist(data0,nclass=10, prob=T, col="coral",density=20,ylim=c(0,0.45),main="Put here the title")
# now plot also the density
xgrid=seq(min(data0)-0.5,max(data0)+0.5,0.01) # ponit in which you will evaluate the density
hist(data0,nclass=10, prob=T, density=20, col="coral", ylim=c(0,0.45),xlim=c(min(xgrid),max(xgrid)),main="Data",xlab="x",ylab="pdf")
# note that there are more info here wrt the previous hist
lines(xgrid,dnorm(xgrid,0,1), col="brown", lwd=2)
abline(v=mean(data0),col="gold", lwd=4,lty=3)
x=rnorm(100)
y=2*x+rnorm(100,0,2)
plot(x,y,xlim=c(-5,5),ylim=c(-10,10),pch=19,  col=4) # draw a scatterplot of x against y
#boxplot(x, col="greenyellow") # compute and plot a box-and-whiskers plot of x
boxplot(x,y,col="greenyellow") # compute and plot a box-and-whiskers plot of x and y
data1=sunspot.month
data1=as.numeric(data1)
mdata=mean(data1)
vardata=var(data1)
x=seq(0,250,1) # make a grid of point
y=dexp(x,1/mdata) # compute the density of an exp of parameter lambda=1/mdata on the grid
ycdf=pexp(x,1/mdata) # same for the CDF
par(mfrow=c(1,2))
## plot the histogram and an estimated density
hist(data1,probability = TRUE,main="Density: sunspots",xlab="x",col="coral",density=20)
lines(x,y,col="red", lwd=2.5)
## plot the emp. cdf  and an estimated cdf
empiricalcdf=ecdf(data1)
plot(empiricalcdf,main="CDF:sunspots")
lines(x,ycdf,col="red", lwd=2.5)
coemissionspercapita <-  read.csv("data/coemissions-per-capita.csv") # this is in my laptop!
coemissionspercapita=data.frame(coemissionspercapita)
data=coemissionspercapita[coemissionspercapita$Entity=="Italy",3:4]
#
plot(data,type="l",main="CO2 em. per cap. Italy",xlab="year",ylab="CO2")
#
emission_b40=data[data$Year<1940,2]
emission_40_80=data[data$Year>=1940& data$Year<1980,2]
emission_a80=data[data$Year>=1980,2]
#
hist(emission_b40,col="coral",density=20,main="CO2 em. per cap. Italy",xlim=c(0,10),probability=TRUE)
#hist(emission_40_80,col="green",density=20,add=TRUE,probability=TRUE)
hist(emission_a80,col="blue",density=20,add=TRUE,probability=TRUE)
legend(x=7,y=1.5,legend=c("<1940","1980-2022"),col=c("coral","blue"),lty=1)
#
#
climatechange <-  read.csv("data/climate-change.csv") # this is in my laptop!
C02data_all=data.frame(climatechange[climatechange$Entity=="World",2:3])
head(C02data_all)
plot(C02data_all,type="l",main="CO2")
#
C02data_BC=data.frame(C02data_all[C02data_all$Year<0,1:2])
C02data_AC=data.frame(C02data_all[C02data_all$Year>0,1:2])
head(C02data_AC)
plot(C02data_AC,type="l",main="CO2")
C02data_850=data.frame(C02data_all[C02data_all$Year>1850,1:2])
hist(C02data_BC[,2],20,col="green",density=20,probability = TRUE,xlim=c(160,400),xlab="CO2",ylab="pdf",main="CO2 form -8*10^5 to 0 vs mean 1850-2022")
abline(v=mean(C02data_850[is.na(C02data_850[,2])==0,2]),col="gold", lwd=4,lty=3)
