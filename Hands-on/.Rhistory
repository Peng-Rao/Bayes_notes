library(readxl) ## need this library to read .xlsx files
##
temperature <- data.frame(read_excel("data/ATS.xlsx"))
years=-temperature[,1]+1950
n=5000
#
plot(years[1:n],temperature[1:n,2],type="l",col="red",ylim=c(-10,10))
lines(C02data_all$Year[C02data_all$Year>years[n]],C02data_all$CO2.concentrations[C02data_all$Year>years[n]]/20-10,col="blue")
abline(v=1700,col="gold")
abline(v=0,col="green")
plot(years[years>0],temperature[years>0,2],type="l",col="red",ylim=c(-10,10))
lines(C02data_all$Year[C02data_all$Year>0],C02data_all$CO2.concentrations[C02data_all$Year>0]/20-10,col="blue")
abline(v=1700,col="gold")
abline(v=0,col="green")
